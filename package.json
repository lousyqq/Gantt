{
  "name": "gantt-client",
  "version": "1.0.0",
  "private": true,
  "description": "前端建置：把 JSX 預編譯成 wwwroot/app.js，並把 Tailwind 編譯成 wwwroot/app.css",
  "scripts": {
    "build:js": "babel ClientApp/app.jsx --presets @babel/preset-react --out-file wwwroot/app.js",
    "build:css": "tailwindcss -i ClientApp/input.css -o wwwroot/app.css --minify",
    "build": "npm run build:js && npm run build:css && node scripts/stamp-assets.js",
    "watch:js": "babel ClientApp/app.jsx --presets @babel/preset-react --out-file wwwroot/app.js --watch",
    "watch:css": "tailwindcss -i ClientApp/input.css -o wwwroot/app.css --watch"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.0",
    "@babel/core": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "tailwindcss": "^3.4.0"
  }
}
